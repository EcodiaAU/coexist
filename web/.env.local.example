# Co-Exist marketing site - local env. Copy to web/.env.local and fill in.
# Supabase project: tjutlbzekfouwsiaplbr (Co-Exist). See backend docs/secrets/coexist-supabase.md.

# Public (browser-safe)
NEXT_PUBLIC_SUPABASE_URL=https://tjutlbzekfouwsiaplbr.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only. Used to compute accurate public impact totals from RLS-locked
# tables (event_impact is authenticated-only). NEVER expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# Canonical URLs
NEXT_PUBLIC_APP_URL=https://app.coexistaus.org
NEXT_PUBLIC_SITE_URL=https://coexistaus.org
