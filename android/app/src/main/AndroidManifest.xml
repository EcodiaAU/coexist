<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/AppTheme">

        <activity
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|locale|smallestScreenSize|screenLayout|uiMode|navigation|density"
            android:name=".MainActivity"
            android:theme="@style/AppTheme.NoActionBarLaunch"
            android:launchMode="singleTask"
            android:exported="true"
            android:windowSoftInputMode="adjustNothing">
            <!--
                adjustNothing keeps the WebView at full height when the soft
                keyboard opens (iOS-equivalent). Android default adjustResize
                compounds with the JS layer kb-height + scroll-margin-bottom
                + scrollIntoView avoidance and pushes focused inputs WAY
                off-screen. Tate verbatim 2026-05-28. Capacitor keyboard
                plugin setResizeMode is unimplemented on Android, so the
                Keyboard.resize none in capacitor.config.ts is a no-op
                here; manifest flag is the real switch.
            -->

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!-- Deep links: coexist:// scheme -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="coexist" />
            </intent-filter>

            <!-- App Links: autoVerify on the marketing host plus the
                 web/app host. Both must publish
                 .well-known/assetlinks.json with the matching package
                 SHA256 fingerprint for autoVerify to succeed on
                 Android 12+. app.coexistaus.org carries event deep
                 links from emails (RSVP buttons land on /events/<id>)
                 so adding it here is what lets the native app
                 intercept those taps instead of the browser. -->
            <intent-filter android:autoVerify="true">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="https" android:host="coexistaus.org" />
                <data android:scheme="https" android:host="app.coexistaus.org" />
            </intent-filter>

            <!-- Secondary hosts: QR check-in (app.coexist.au) + short link
                 (coexist.au). Without autoVerify the OS shows the "Open with"
                 chooser the first time, then remembers. Adding these closes
                 the gap where scanning the public QR (URL hardcoded to
                 https://app.coexist.au/check-in/{token} in event-day.tsx)
                 silently opened the browser even when Co-Exist was
                 installed. Publish assetlinks.json at these hosts to lift
                 them into autoVerify too. -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="https" android:host="app.coexist.au" />
                <data android:scheme="https" android:host="coexist.au" />
            </intent-filter>

        </activity>

        <!-- Override ML Kit barcode scanner to remove portrait-only restriction (Android 16+
             ignores orientation locks on large screens; removing avoids layout issues on
             foldables/tablets) -->
        <activity
            android:name="com.google.mlkit.vision.codescanner.internal.GmsBarcodeScanningDelegateActivity"
            android:screenOrientation="unspecified"
            android:resizeableActivity="true"
            tools:replace="android:screenOrientation,android:resizeableActivity" />

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths"></meta-data>
        </provider>

        <!-- Backported Android Photo Picker via Google Play services for devices on
             Android < 11 (and Android Go on 11/12). Without this, the gallery picker
             can fall back to a generic document picker that doesn't show the photo
             library natively. See @capacitor/camera README. -->
        <service
            android:name="com.google.android.gms.metadata.ModuleDependencies"
            android:enabled="false"
            android:exported="false"
            tools:ignore="MissingClass">
            <intent-filter>
                <action android:name="com.google.android.gms.metadata.MODULE_DEPENDENCIES" />
            </intent-filter>
            <meta-data android:name="photopicker_activity:0:required" android:value="" />
        </service>
    </application>

    <!-- Permissions -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.READ_CALENDAR" />
    <uses-permission android:name="android.permission.WRITE_CALENDAR" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <!-- Gallery access: no broad media permission needed.
         Android 10+ (SDK 29+) reaches the system gallery picker via the Capacitor
         camera plugin without permissions (IonCameraFlow.kt:994 - "Android 10+ does
         not require storage permissions to use the system gallery picker"). Older
         devices (SDK 24-32) fall back to READ_EXTERNAL_STORAGE, gated by
         maxSdkVersion="32" so it never lands on Android 13+.
         READ_MEDIA_IMAGES was rejected by Play policy review on 2026-06-04 (Co-Exist
         v33) because the app does not need broad gallery access - only user-selected
         photos for profile/event uploads. Removing satisfies the photo-and-video
         permissions policy. -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" android:maxSdkVersion="32" />
</manifest>
