<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Base application theme. NoActionBar parent (was Light.DarkActionBar
         until 2026-06-01) so no sub-activity in the app graph can inherit a
         DarkActionBar. The 2026-05-28 + 2026-06-01 black-banner fixes
         operate on the launch theme + MainActivity.onCreate flow; locking
         the application-level theme here means nothing else (e.g. third
         party activities, lazy-launched sub-screens) can resurrect the
         ActionBar by inheriting from the app theme. -->
    <style name="AppTheme" parent="Theme.AppCompat.Light.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorAccent">@color/colorAccent</item>
    </style>

    <style name="AppTheme.NoActionBar" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="android:background">@null</item>
        <!-- Prevent the parent AppCompat theme's default window background (white/grey)
             from bleeding through the transparent status bar before WebView renders -->
        <item name="android:windowBackground">@color/splashBackground</item>
        <!-- Edge-to-edge: let the system draw transparent bars; content draws behind them -->
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar">true</item>
    </style>


    <!-- Launch theme: Android 12+ system splash API.
         Android 12+ ignores android:background on Theme.SplashScreen and instead
         uses windowSplashScreenBackground + windowSplashScreenAnimatedIcon.
         The icon is auto-centered (~108dp inside a 288dp safe area).
         postSplashScreenTheme hands off to the normal app theme once the WebView is ready.

         windowActionBar/windowNoTitle (AppCompat attrs, no android: prefix) MUST be
         set here. Theme.SplashScreen only sets the framework android:windowActionBar
         flag - so when BridgeActivity.super.onCreate() runs under this theme, the
         AppCompat delegate doesn't see the no-action-bar signal and installs a
         dark ActionBar showing the activity's android:label ("Co-Exist"). The
         subsequent setTheme(AppTheme.NoActionBar) inside BridgeActivity.onCreate
         swaps the theme but does NOT remove the already-installed ActionBar.
         Tate verbatim 2026-05-28: persistent black "Co-Exist" header on mum's
         Android device, light/dark mode both. -->
    <style name="AppTheme.NoActionBarLaunch" parent="Theme.SplashScreen">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="windowSplashScreenBackground">@color/splashBackground</item>
        <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcher</item>
        <item name="postSplashScreenTheme">@style/AppTheme.NoActionBar</item>
    </style>
</resources>